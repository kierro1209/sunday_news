# Google AI Studio key (aistudio.google.com) — Create API key -> copy key
GEMINI_API_KEY=

# Optional override if a model is quota-blocked (default: gemini-3-flash-preview)
# GEMINI_MODEL=gemini-3-flash-preview

# Supabase project (Settings -> API)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Resend (resend.com) — without a verified domain you can send from
# onboarding@resend.dev to your own Resend account email only.
RESEND_API_KEY=
EMAIL_FROM=The Magnolia Times <onboarding@resend.dev>
EMAIL_TO=you@example.com

# Where the web app lives (linked from the email); optional
WEB_APP_URL=http://localhost:3000
